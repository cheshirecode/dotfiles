def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_iso(value: str) -> float:
    return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()


def cache_root() -> pathlib.Path:
    base = os.environ.get("WHICH_MODEL_CACHE_HOME")
    if base:
        return pathlib.Path(base).expanduser()
    xdg = os.environ.get("XDG_CACHE_HOME")
    if xdg:
        return pathlib.Path(xdg).expanduser() / "which-model"
    home = pathlib.Path.home()
    if str(home):
        return home / ".cache" / "which-model"
    return pathlib.Path(tempfile.gettempdir()) / "which-model"


def cache_path(env: str, provider: str | None = None) -> pathlib.Path:
    suffix = f".{provider}" if provider else ""
    return cache_root() / f"catalog.{env}{suffix}.json"


def detect_process_env() -> str | None:
    harnesses = {"claude", "codex", "cursor", "opencode"}
    pid = os.getppid()
    seen: set[int] = set()
    deadline = time.monotonic() + 2
    for _ in range(12):
        if pid <= 1 or pid in seen:
            return None
        seen.add(pid)
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return None
        try:
            proc = subprocess.run(
                ["ps", "-o", "ppid=,args=", "-p", str(pid)],
                check=False,
                text=True,
                capture_output=True,
                timeout=min(0.25, remaining),
            )
        except (OSError, subprocess.TimeoutExpired):
            return None
        if proc.returncode != 0:
            return None
        parts = proc.stdout.strip().split(None, 1)
        if len(parts) != 2:
            return None
        try:
            pid = int(parts[0])
        except ValueError:
            return None
        argv0 = parts[1].split(None, 1)[0]
        executable = pathlib.Path(argv0).name.lstrip("-").lower()
        if executable in harnesses:
            return executable
    return None


def detect_env() -> str:
    explicit = os.environ.get("WHICH_MODEL_ENV", "").strip().lower()
    if explicit in ENVS:
        return explicit
    if os.environ.get("CODEX_SANDBOX"):
        return "codex"
    if os.environ.get("CLAUDE_CODE_SESSION_ID"):
        return "claude"
    if os.environ.get("CURSOR_SESSION_ID") or os.environ.get("CURSOR_TRACE_ID"):
        return "cursor"
    if os.environ.get("OPENCODE") or os.environ.get("OPENCODE_SESSION_ID"):
        return "opencode"
    process_env = detect_process_env()
    if process_env:
        return process_env
    if os.environ.get("CODEX_HOME"):
        return "codex"
    cwd = pathlib.Path.cwd()
    if (cwd / "opencode.json").exists() or (cwd / ".opencode").exists():
        return "opencode"
    if (cwd / ".cursor").exists():
        return "cursor"
    if (cwd / ".claude").exists():
        return "claude"
    if os.environ.get("OPENROUTER_API_KEY"):
        return "openrouter"
    return "unknown"


def normalize_task(value: str | None) -> str | None:
    if not value:
        return None
    lowered = value.lower()
    for needle, tag in TASK_ALIASES.items():
        if needle in lowered:
            return tag
    return lowered.strip().replace(" ", "_")


def atomic_write_json(path: pathlib.Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", dir=path.parent, prefix=f".{path.name}.", delete=False) as tmp:
        json.dump(payload, tmp, indent=2, sort_keys=True)
        tmp.write("\n")
        tmp_path = pathlib.Path(tmp.name)
    tmp_path.replace(path)


def load_json_url(url: str) -> object:
    with urllib.request.urlopen(url, timeout=15) as response:
        return json.loads(response.read().decode("utf-8"))


def load_json_file(path: pathlib.Path) -> object:
    return json.loads(path.read_text())


def local_source_payload() -> object | None:
    source = os.environ.get("WHICH_MODEL_CATALOG_SOURCE")
    if not source:
        return None
    if re.match(r"^https?://", source):
        return load_json_url(source)
    return load_json_file(pathlib.Path(source).expanduser())


def from_models_dev(payload: object, env: str) -> list[dict]:
    models: list[dict] = []
    records: list[tuple[str, dict]] = []
    if isinstance(payload, dict):
        for provider, provider_data in payload.items():
            if not isinstance(provider_data, dict):
                continue
            provider_models = provider_data.get("models")
            if isinstance(provider_models, dict):
                records.extend((provider, model) for model in provider_models.values() if isinstance(model, dict))
            elif isinstance(provider_models, list):
                records.extend((provider, model) for model in provider_models if isinstance(model, dict))
            elif "id" in provider_data:
                records.append((provider, provider_data))
    elif isinstance(payload, list):
        records.extend(("unknown", model) for model in payload if isinstance(model, dict))

    for provider, item in records:
        model_id = item.get("id") or item.get("slug") or item.get("name")
        if not model_id:
            continue
        pricing = item.get("pricing") or {}
        context = item.get("context") or item.get("limits") or {}
        capabilities = item.get("capabilities") or item.get("features") or {}
        modalities = item.get("modalities") or {}
        cap_list = sorted(
            {
                key
                for group in (capabilities, modalities)
                if isinstance(group, dict)
                for key, enabled in group.items()
                if enabled
            }
        )
        if not cap_list:
            cap_list = ["text"]
        task_fit = infer_task_fit(str(model_id), cap_list)
        models.append(
            {
                "id": str(model_id),
                "display_name": str(item.get("name") or model_id),
                "provider": str(item.get("provider") or provider),
                "availability": "requires_harness_check" if env != "opencode" else "selectable_if_configured",
                "input_price_per_mtok": number_or_none(pricing.get("input") or pricing.get("input_price")),
                "output_price_per_mtok": number_or_none(pricing.get("output") or pricing.get("output_price")),
                "context_window": int_or_none(context.get("context") or context.get("input") or item.get("context_length")),
                "max_output": int_or_none(context.get("output") or item.get("max_output")),
                "capabilities": cap_list,
                "task_fit": task_fit,
                "caveats": [],
                "confidence": "fresh",
            }
        )
    return models


def price_per_mtok(value: object) -> float | None:
    """OpenRouter lists per-token USD prices as strings; scale to per-million-token."""
    per_token = number_or_none(value)
    if per_token is None or per_token < 0:
        # OpenRouter uses negative sentinels (e.g. "-1") for dynamic/variable pricing.
        return None
    return round(per_token * 1_000_000, 6)


def from_openrouter(payload: object, env: str, *, confidence: str = "fresh") -> list[dict]:
    del env  # OpenRouter normalization is env-specific already at the call site.
    if isinstance(payload, dict):
        records = payload.get("data")
    else:
        records = payload
    if not isinstance(records, list):
        return []

    models: list[dict] = []
    for item in records:
        if not isinstance(item, dict):
            continue
        model_id = item.get("id") or item.get("canonical_slug")
        if not model_id:
            continue
        model_id = str(model_id)
        pricing = item.get("pricing") if isinstance(item.get("pricing"), dict) else {}
        architecture = item.get("architecture") if isinstance(item.get("architecture"), dict) else {}
        top_provider = item.get("top_provider") if isinstance(item.get("top_provider"), dict) else {}
        supported = item.get("supported_parameters") or []
        supported_set = {str(param).lower() for param in supported if isinstance(param, str)}
        reasoning_meta = item.get("reasoning") if isinstance(item.get("reasoning"), dict) else {}

        cap_set = {"text"}
        for modality in architecture.get("input_modalities") or []:
            if modality == "image":
                cap_set.add("image_input")
            elif isinstance(modality, str) and modality not in {"text"}:
                cap_set.add(modality)
        cap_set.add("code")
        if "tools" in supported_set or "tool_choice" in supported_set:
            cap_set.add("tools")
        if "reasoning" in supported_set or "include_reasoning" in supported_set or reasoning_meta:
            cap_set.add("reasoning")
        if "structured_outputs" in supported_set or "response_format" in supported_set:
            cap_set.add("structured_output")
        cap_list = sorted(cap_set)

        advertised_context = int_or_none(item.get("context_length"))
        routed_context = int_or_none(top_provider.get("context_length"))
        # Prefer the routed/top_provider window; fall back to advertised length.
        context_window = routed_context if routed_context is not None else advertised_context
        input_price = price_per_mtok(pricing.get("prompt"))
        output_price = price_per_mtok(pricing.get("completion"))

        caveats: list[str] = []
        if top_provider.get("is_moderated"):
            caveats.append("OpenRouter reports this route as moderated.")
        if (
            advertised_context is not None
            and routed_context is not None
            and advertised_context != routed_context
        ):
            caveats.append(
                f"Advertised context ({advertised_context}) differs from routed top_provider "
                f"context ({routed_context}); using routed value."
            )
        if routed_context is None:
            caveats.append("Missing routed context from top_provider; advertised length may not apply.")
        if input_price is None or output_price is None:
            caveats.append("Exact OpenRouter pricing unavailable for this model; do not invent dollar quotes.")
        if reasoning_meta.get("mandatory") is True:
            caveats.append("OpenRouter reports reasoning as mandatory for this model.")
        expiration = item.get("expiration_date")
        if isinstance(expiration, str) and expiration.strip():
            caveats.append(f"OpenRouter lists expiration_date={expiration.strip()}.")

        models.append(
            {
                "id": model_id,
                "display_name": str(item.get("name") or model_id),
                "provider": model_id.split("/", 1)[0] if "/" in model_id else "openrouter",
                "availability": "selectable_here",
                "input_price_per_mtok": input_price,
                "output_price_per_mtok": output_price,
                "context_window": context_window,
                "max_output": int_or_none(top_provider.get("max_completion_tokens")),
                "capabilities": cap_list,
                "task_fit": infer_task_fit(model_id, cap_list),
                "caveats": caveats,
                "confidence": confidence,
            }
        )
    return models


# Curated Anthropic model metadata (docs snapshot; see ANTHROPIC_PRICING_SNAPSHOT).
# Rules are matched most-specific-first against the lowercased model id. The Models
# API supplies the id/display_name/availability; these fields fill the gaps it omits.
ANTHROPIC_MODEL_METADATA: list[tuple[tuple[str, ...], dict]] = [
    (("haiku-4",), {
