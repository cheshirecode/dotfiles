def anthropic_metadata(model_id: str) -> dict | None:
    lowered = model_id.lower()
    for needles, metadata in ANTHROPIC_MODEL_METADATA:
        if any(needle in lowered for needle in needles):
            return metadata
    return None


# Dated docs snapshot of selectable Claude model IDs (see ANTHROPIC_PRICING_SNAPSHOT).
# Used when the LLM session does not inject a live Models API result. IDs are chosen to
# match the metadata rules above; enrichment fills pricing/limits/capabilities.
ANTHROPIC_CATALOG_SNAPSHOT: list[dict] = [
    {"id": "claude-opus-4-1", "display_name": "Claude Opus 4.1"},
    {"id": "claude-sonnet-4-5", "display_name": "Claude Sonnet 4.5"},
    {"id": "claude-haiku-4-5", "display_name": "Claude Haiku 4.5"},
    {"id": "claude-3-7-sonnet-latest", "display_name": "Claude Sonnet 3.7"},
    {"id": "claude-3-5-sonnet-latest", "display_name": "Claude Sonnet 3.5"},
    {"id": "claude-3-5-haiku-latest", "display_name": "Claude Haiku 3.5"},
    {"id": "claude-3-opus-latest", "display_name": "Claude Opus 3"},
    {"id": "claude-3-haiku-20240307", "display_name": "Claude Haiku 3"},
]


def from_anthropic(payload: object, env: str, *, confidence: str = "fresh") -> list[dict]:
    del env
    if isinstance(payload, dict):
        records = payload.get("data")
    else:
        records = payload
    if not isinstance(records, list):
        return []

    models: list[dict] = []
    for item in records:
        if not isinstance(item, dict):
            continue
        model_id = item.get("id")
        if not model_id:
            continue
        model_id = str(model_id)
        metadata = anthropic_metadata(model_id)
        capabilities = list(metadata["capabilities"]) if metadata else ["text", "code"]
        caveats: list[str] = []
        if metadata:
            caveats.append(
                f"Pricing/context/limits from Anthropic docs snapshot {ANTHROPIC_PRICING_SNAPSHOT}; "
                "verify against current pricing before billing decisions."
            )
        else:
            caveats.append(
                "No pricing/limits metadata match for this model id; refresh the docs snapshot "
                "before quoting dollars or context limits."
            )
        models.append(
            {
                "id": model_id,
                "display_name": str(item.get("display_name") or model_id),
                "provider": "anthropic",
                # The Models API confirms account access; harness may still gate selection.
                "availability": "selectable_if_configured",
                "input_price_per_mtok": metadata.get("input_price_per_mtok") if metadata else None,
                "output_price_per_mtok": metadata.get("output_price_per_mtok") if metadata else None,
                "context_window": metadata.get("context_window") if metadata else None,
                "max_output": metadata.get("max_output") if metadata else None,
                "capabilities": capabilities,
                "task_fit": infer_task_fit(model_id, capabilities),
                "caveats": caveats,
                "confidence": confidence,
            }
        )
    return models


def number_or_none(value: object) -> float | None:
    if value is None:
        return None
    try:
        return float(value)
    except (TypeError, ValueError):
        return None


def int_or_none(value: object) -> int | None:
    if value is None:
        return None
    try:
        return int(float(value))
    except (TypeError, ValueError):
        return None


def infer_task_fit(model_id: str, capabilities: list[str]) -> list[str]:
    lowered = model_id.lower()
    tags = {"mechanical_search"}
    if any(
        token in lowered
        for token in (
            "code",
            "coder",
            "claude",
            "gpt",
            "qwen",
            "kimi",
            "deepseek",
            "composer",
            "grok",
            "gemini",
            "glm",
            "mimo",
            "minimax",
        )
    ):
        tags.add("routine_coding")
    if any(token in lowered for token in ("pro", "opus", "sonnet", "sol", "reason", "fable")):
        tags.add("planning")
        tags.add("final_synthesis")
    if any(token in lowered for token in ("mini", "haiku", "nano", "luna", "flash")):
        tags.add("cheap_parallel_voter")
    if any(cap in capabilities for cap in ("image", "image_input", "vision")):
        tags.add("visual_design")
    return sorted(tags)


def run_opencode_models() -> list[dict]:
    if os.environ.get("WHICH_MODEL_SKIP_OPENCODE_CLI"):
        return []
    try:
        proc = subprocess.run(
            ["opencode", "models"],
            check=False,
            text=True,
            capture_output=True,
            timeout=15,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return []
    if proc.returncode != 0:
        return []
    models = []
    for line in proc.stdout.splitlines():
        line = line.strip()
        if not line or line.startswith(("Provider", "---")):
            continue
        if "/" not in line:
            continue
        model_id = line.split()[0]
        models.append(
            {
                "id": model_id,
                "display_name": model_id,
                "provider": model_id.split("/", 1)[0],
                "availability": "selectable_here",
                "input_price_per_mtok": None,
                "output_price_per_mtok": None,
                "context_window": None,
                "max_output": None,
                "capabilities": ["text", "code", "tools"],
                "task_fit": infer_task_fit(model_id, ["text", "code", "tools"]),
                "caveats": ["Price/capability enrichment may come from Models.dev if available."],
                "confidence": "fresh",
            }
        )
    return models


def cursor_state_db_candidates() -> list[pathlib.Path]:
    override = os.environ.get("WHICH_MODEL_CURSOR_STATE_DB")
    if override:
        return [pathlib.Path(override).expanduser()]
    home = pathlib.Path.home()
    return [
        home / "Library" / "Application Support" / "Cursor" / "User" / "globalStorage" / "state.vscdb",
        home / ".config" / "Cursor" / "User" / "globalStorage" / "state.vscdb",
        home / "AppData" / "Roaming" / "Cursor" / "User" / "globalStorage" / "state.vscdb",
    ]


def load_cursor_reactive_storage(db_path: pathlib.Path) -> dict | None:
    if not db_path.is_file():
        return None
    try:
        with sqlite3.connect(f"file:{db_path}?mode=ro", uri=True) as connection:
            rows = connection.execute(
                "SELECT key, value FROM ItemTable WHERE key LIKE ?",
                ("%reactivestorage%persistentStorage%",),
            ).fetchall()
    except sqlite3.Error:
        return None
    for _key, value in rows:
        if not isinstance(value, str):
            continue
        try:
            payload = json.loads(value)
        except json.JSONDecodeError:
            continue
        if isinstance(payload, dict) and isinstance(payload.get("availableDefaultModels2"), list):
            return payload
    return None


def strip_html_text(value: str) -> str:
    no_tags = re.sub(r"<[^>]+>", " ", value)
    return re.sub(r"\s+", " ", html.unescape(no_tags)).strip()


def cursor_provider_for(model_id: str) -> str:
    lowered = model_id.lower()
    if "/" in model_id:
        return model_id.split("/", 1)[0]
    if lowered.startswith(("claude", "anthropic")):
        return "anthropic"
    if lowered.startswith(("gpt", "o1", "o3", "o4", "codex")):
        return "openai"
    if lowered.startswith("gemini"):
        return "google"
    if lowered.startswith(("grok", "composer", "cursor", "default")):
        return "cursor"
    if lowered.startswith(("glm", "z-ai")):
        return "z-ai"
    if lowered.startswith(("kimi", "moonshot")):
        return "moonshot"
    if lowered.startswith(("mimo", "xiaomi")):
        return "xiaomi"
    if lowered.startswith("minimax"):
        return "minimax"
    return "cursor"


def parse_cursor_context_window(tooltip_markdown: str | None) -> int | None:
    if not tooltip_markdown:
        return None
    match = re.search(r"(\d+(?:\.\d+)?)\s*k\s*context", tooltip_markdown, flags=re.IGNORECASE)
    if match:
        return int(float(match.group(1)) * 1000)
    match = re.search(r"(\d[\d,]*)\s*context window", tooltip_markdown, flags=re.IGNORECASE)
    if match:
        return int(match.group(1).replace(",", ""))
    return None


def from_cursor(payload: object, env: str, *, confidence: str = "fresh") -> list[dict]:
    del env
    if not isinstance(payload, dict):
        return []

    records = payload.get("availableDefaultModels2")
    if not isinstance(records, list):
        # Allow fixtures that pass the model list at the top level under "models".
        records = payload.get("models")
    if not isinstance(records, list):
        return []

    ai_settings = payload.get("aiSettings") if isinstance(payload.get("aiSettings"), dict) else {}
    disabled = {
        str(item)
        for item in (ai_settings.get("modelOverrideDisabled") or [])
        if isinstance(item, str)
    }
    enabled = {
        str(item)
        for item in (ai_settings.get("modelOverrideEnabled") or [])
        if isinstance(item, str)
    }
    user_added = {
        str(item)
        for item in (ai_settings.get("userAddedModels") or [])
        if isinstance(item, str)
    }

    models: list[dict] = []
    for item in records:
        if not isinstance(item, dict):
            continue
        model_id = item.get("name") or item.get("id")
        if not model_id:
            continue
        model_id = str(model_id)
        if model_id in {"default", "auto"}:
            # Auto/default is a router lane, not an exact model recommendation target.
            continue

        variants = item.get("variants") if isinstance(item.get("variants"), list) else []
        display_name = model_id
        tooltip = ""
        for variant in variants:
            if not isinstance(variant, dict):
                continue
            raw_name = variant.get("displayNameOutsidePicker") or variant.get("displayName")
            if isinstance(raw_name, str) and raw_name.strip():
                cleaned = strip_html_text(raw_name)
                if cleaned:
                    display_name = cleaned
                    break
        for variant in variants:
            if not isinstance(variant, dict):
                continue
            tooltip_data = variant.get("tooltipData") if isinstance(variant.get("tooltipData"), dict) else {}
            markdown = tooltip_data.get("markdownContent")
            if isinstance(markdown, str) and markdown.strip():
                tooltip = markdown
                break

        cap_set = {"text", "code"}
        if item.get("supportsAgent"):
            cap_set.add("tools")
        param_ids = {
            str(param.get("id")).lower()
            for param in (item.get("parameterDefinitions") or [])
            if isinstance(param, dict) and param.get("id")
        }
        if "effort" in param_ids or "thinking" in model_id.lower() or "reasoning" in tooltip.lower():
            cap_set.add("reasoning")
        if re.search(r"\b(image|vision|multimodal)\b", tooltip, flags=re.IGNORECASE):
            cap_set.add("image_input")
        cap_list = sorted(cap_set)

        context_window = parse_cursor_context_window(tooltip)
        caveats = [
            "Cursor local state does not expose exact token pricing; do not invent dollar quotes.",
        ]
        if context_window is not None:
            caveats.append("Context window parsed from Cursor model tooltip text.")
        else:
            caveats.append("Context window not present in Cursor local model state.")

        if model_id in disabled:
            availability = "requires_harness_check"
            caveats.append("Disabled in Cursor model picker overrides.")
        else:
            availability = "selectable_here"
            if model_id in enabled or model_id in user_added:
                caveats.append("Explicitly enabled or user-added in Cursor model overrides.")
            elif item.get("defaultOn") is False:
                caveats.append("Present in Cursor catalog but not default-on; confirm plan access.")

        models.append(
            {
                "id": model_id,
                "display_name": display_name,
                "provider": cursor_provider_for(model_id),
                "availability": availability,
                "input_price_per_mtok": None,
                "output_price_per_mtok": None,
                "context_window": context_window,
                "max_output": None,
                "capabilities": cap_list,
                "task_fit": infer_task_fit(model_id, cap_list),
                "caveats": caveats,
                "confidence": confidence,
            }
        )
    return models


def load_cursor_catalog_payload() -> tuple[dict | None, dict]:
    """Return (payload, source_meta). payload is None when unavailable."""
    for db_path in cursor_state_db_candidates():
        payload = load_cursor_reactive_storage(db_path)
        if payload is not None:
            return payload, {"kind": "cursor-state-db", "path": str(db_path)}
        if db_path.is_file():
            return None, {
                "kind": "cursor-state-db",
                "path": str(db_path),
                "error": "reactive storage with availableDefaultModels2 not found",
            }
    return None, {
        "kind": "cursor-state-db",
        "error": "Cursor state.vscdb not found in default locations",
    }


def override_confidence(source: str | None) -> str:
    """Local fixture files are deterministic; URL overrides are treated as fresh fetches."""
    if source and re.match(r"^https?://", source):
        return "fresh"
    return "fixture"


def build_catalog(env: str, provider: str) -> dict:
    sources: list[dict] = []
    models: list[dict] = []
    source_payload = local_source_payload()
    if source_payload is not None:
        source_value = os.environ.get("WHICH_MODEL_CATALOG_SOURCE")
        if provider == "openrouter":
            models = from_openrouter(
                source_payload,
                env,
                confidence=override_confidence(source_value),
            )
        elif provider == "claude":
            models = from_anthropic(
                source_payload,
                env,
                confidence=override_confidence(source_value),
            )
        elif provider == "cursor":
            models = from_cursor(
                source_payload,
                env,
                confidence=override_confidence(source_value),
            )
        else:
            models = from_models_dev(source_payload, env)
        sources.append({"kind": "override", "value": source_value})
    elif provider == "openrouter":
        if not os.environ.get("WHICH_MODEL_OFFLINE"):
            try:
                models.extend(from_openrouter(load_json_url(OPENROUTER_MODELS_URL), env, confidence="fresh"))
                sources.append({"kind": "openrouter", "url": OPENROUTER_MODELS_URL})
            except Exception as exc:  # noqa: BLE001 - fallback cache is intentional here.
                sources.append({"kind": "openrouter", "error": str(exc)})
    elif provider == "claude":
        # The running LLM session — not this skill — is what can list live models; it
        # injects that result via WHICH_MODEL_CATALOG_SOURCE (handled above). With no
        # injection we build from the dated docs snapshot: no API key, no network.
        models.extend(from_anthropic(ANTHROPIC_CATALOG_SNAPSHOT, env, confidence="snapshot"))
        sources.append({"kind": "anthropic-docs-snapshot", "snapshot": ANTHROPIC_PRICING_SNAPSHOT})
    elif provider == "cursor":
        if not os.environ.get("WHICH_MODEL_OFFLINE"):
            cursor_payload, cursor_source = load_cursor_catalog_payload()
            sources.append(cursor_source)
            if cursor_payload is not None:
                models.extend(from_cursor(cursor_payload, env, confidence="fresh"))
    elif provider == "opencode":
        models.extend(run_opencode_models())
        if models:
            sources.append({"kind": "opencode", "command": "opencode models"})
        if not os.environ.get("WHICH_MODEL_OFFLINE"):
            try:
                models.extend(from_models_dev(load_json_url("https://models.dev/catalog.json"), env))
                sources.append({"kind": "models.dev", "url": "https://models.dev/catalog.json"})
            except Exception as exc:  # noqa: BLE001 - fallback cache is intentional here.
                sources.append({"kind": "models.dev", "error": str(exc)})

    if not models:
        seed_profile = env if provider == "auto" else provider
        models = copy.deepcopy(ENV_SEEDS.get(seed_profile, ENV_SEEDS["unknown"]))
        sources.append({"kind": "seed", "value": seed_profile})

    generated = time.time()
    return {
        "schema_version": SCHEMA_VERSION,
        "environment": env,
        "provider": provider,
        "generated_at": now_iso(),
        "stale_after": datetime.fromtimestamp(generated + STALE_AFTER_SECONDS, timezone.utc)
        .replace(microsecond=0)
        .isoformat()
        .replace("+00:00", "Z"),
        "sources": sources,
        "models": dedupe_models(models),
    }


def dedupe_models(models: list[dict]) -> list[dict]:
    seen: dict[str, dict] = {}
    for model in models:
        seen.setdefault(model["id"], model)
    return sorted(seen.values(), key=lambda item: (item.get("provider", ""), item.get("id", "")))


def read_catalog(path: pathlib.Path) -> dict | None:
    if not path.is_file():
        return None
    return json.loads(path.read_text())


def is_stale(catalog: dict) -> bool:
    stale_after = catalog.get("stale_after")
    if not stale_after:
        return True
    return parse_iso(stale_after) <= time.time()


def is_very_stale(catalog: dict) -> bool:
    generated_at = catalog.get("generated_at")
    if not generated_at:
        return True
    return time.time() - parse_iso(generated_at) > VERY_STALE_AFTER_SECONDS


def price_score(model: dict) -> float:
    input_price = model.get("input_price_per_mtok")
    output_price = model.get("output_price_per_mtok")
    if input_price is None and output_price is None:
        return 1000.0
    return float(input_price or 0) + float(output_price or 0)


def rank_models(catalog: dict, task: str | None, top: int) -> list[dict]:
    tag = normalize_task(task)

    def score(model: dict) -> tuple[int, float, str]:
        fits = set(model.get("task_fit") or [])
        availability = model.get("availability")
        fit_penalty = 0 if tag and tag in fits else 1
        availability_penalty = 0 if availability in {"selectable_here", "selectable_if_configured"} else 1
        return (fit_penalty + availability_penalty, price_score(model), model.get("id", ""))

    return sorted(catalog.get("models", []), key=score)[:top]


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--env",
        default="auto",
        help="codex, cursor, claude, opencode, openrouter, unknown, or auto",
    )
    parser.add_argument(
        "--provider",
        default="auto",
        help="codex, cursor, claude, opencode, openrouter, or auto",
    )
    parser.add_argument("--refresh-if-stale", action="store_true")
    parser.add_argument("--force-refresh", action="store_true")
    parser.add_argument("--task", default=None)
    parser.add_argument("--top", type=int, default=3)
    parser.add_argument("--print-path", action="store_true")
    args = parser.parse_args()

    env = detect_env() if args.env == "auto" else args.env
    if env not in ENVS:
        sys.stderr.write(f"model-catalog: unknown env {env!r}\n")
        return 2

    explicit_provider = args.provider != "auto"
    if explicit_provider and args.provider not in PROVIDERS:
        sys.stderr.write(f"model-catalog: unknown provider {args.provider!r}\n")
        return 2
    provider = args.provider if explicit_provider else (env if env in PROVIDERS else "auto")

    path = cache_path(env, provider if explicit_provider else None)
    if args.print_path:
        print(path)
        return 0

    catalog = read_catalog(path)
    should_refresh = args.force_refresh or catalog is None or (args.refresh_if_stale and is_stale(catalog))
    if should_refresh:
        catalog = build_catalog(env, provider)
        atomic_write_json(path, catalog)

    assert catalog is not None
    output = {
        "path": str(path),
        "stale": is_stale(catalog),
        "very_stale": is_very_stale(catalog),
        "catalog": catalog,
    }
    if args.task:
        output["recommendations"] = rank_models(catalog, args.task, args.top)
    json.dump(output, sys.stdout, indent=2, sort_keys=True)
    print()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
