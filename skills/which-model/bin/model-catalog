#!/usr/bin/env python3
"""Build and read an environment-specific model catalog for which-model."""

from __future__ import annotations

import argparse
import json
import os
import pathlib
import re
import subprocess
import sys
import tempfile
import time
import urllib.request
from datetime import datetime, timezone


