#!/usr/bin/env bash
# Worklog post-commit advisory. Fires after every commit (checkpoint, archive,
# autosave, hand-typed git — all paths). TTL-gated so the cross-task lint runs
# at most hourly; otherwise the stamp-file mtime gates it out instantly.
#
# Output: cross-task warning / error counts on stderr. Never blocks.
# Inspect details with the skill `lint.sh --cross-task` or `/worklog lint --cross-task`.
#
# Bypass: `WORKLOG_NO_HOOK=1 git commit ...` (same env as pre-commit).

set -euo pipefail

[[ -n "${WORKLOG_NO_HOOK:-}" ]] && exit 0

cd "$(git rev-parse --show-toplevel)"
SKILL_BIN="$(cd "$(dirname "$0")/.." && pwd)"

STAMP=".cache/cross-task.stamp"
TTL=3600
mtime=$(stat -c %Y "$STAMP" 2>/dev/null || stat -f %m "$STAMP" 2>/dev/null || echo 0)
[[ "$mtime" =~ ^[0-9]+$ ]] || mtime=0
now=$(date +%s)
(( now - mtime > TTL )) || exit 0

"$SKILL_BIN/lint.sh" --cross-task --format=json 2>/dev/null | python3 -c "
import json, sys
try:
  d = json.load(sys.stdin)
  e = d.get('total_errors', 0)
  w = d.get('total_warnings', 0)
  if e or w:
    print(f'post-commit: cross-task — {e} error(s), {w} warning(s)  (run $SKILL_BIN/lint.sh --cross-task to inspect)', file=sys.stderr)
  # If any warning is the body-mention shape (the most common, repeatedly hit
  # during 2026-04 sessions), suggest the auto-stub fix-up. Cheap one-line nudge
  # at the moment of friction. See worklog-review-2026-04 Tier-1 #1.
  body_mention = sum(
    1
    for item in d.get('issues', [])
    for warn in item.get('warnings', [])
    if 'body mentions slug' in warn
  )
  if body_mention:
    print(f'post-commit: {body_mention} body-mention warning(s) — run $SKILL_BIN/lint.sh --fix-related to auto-stub', file=sys.stderr)
except Exception:
  pass
" || true

mkdir -p .cache && touch "$STAMP"
exit 0
